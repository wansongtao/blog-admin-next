    "dayjs": "^1.11.7",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.3",
    "vue": "^3.4.15",
    "vue-router": "^4.2.1",
    "web-storage-plus": "^1.5.1"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.0",
    "@tsconfig/node18": "^2.0.1",
    "@types/jsdom": "^21.1.1",
    "@types/node": "^18.16.14",
    "@types/nprogress": "^0.2.0",
