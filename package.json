    "jsdom": "^22.0.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "sass": "^1.62.1",
    "shelljs": "^0.8.5",
    "tailwindcss": "^3.3.2",
    "typescript": "~5.0.4",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^4.3.8",
